# Private settings - never share these
.env

# Data files - too large for GitHub, backed up separately
data/
!data/
data/*
!data/kingdomino/
data/kingdomino/*
!data/kingdomino/eval_suite_v1.jsonl

# Python
__pycache__/
*.py[cod]
*.pyd
*.pyo
.venv/
venv/
*.egg-info/

# Rust build artifacts
target/
*.so
Cargo.lock

# Reference papers (large PDFs kept locally, backed up separately)
references/

# Checkpoints and large binary artifacts
checkpoints*/
*.pkl
# Exception: allow the best_checkpoint directory
!best_checkpoint/
!best_checkpoint/*.pt

# Training output (checkpoints, buffers, logs)
runs/

training_log_*.jsonl

# Training logs (large, machine-specific)
# Do NOT exclude elo_db.json or elo_games.jsonl — these are project
# artifacts that should be committed

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Temp test directories created during validation runs
tmp_*/

# Claude local context
.claude/
